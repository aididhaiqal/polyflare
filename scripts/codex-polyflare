#!/usr/bin/env bash
#
# codex-polyflare — run the REAL Codex CLI against a LOCAL PolyFlare server, for dev.
#
# It leaves your normal `codex` untouched: your usual `~/.codex/config.toml`
# (→ OpenAI / codex-lb) keeps working. This wrapper uses a SEPARATE CODEX_HOME
# so the two never interfere. Use it to exercise PolyFlare with genuine codex-rs
# traffic — and to capture the real codex-rs request fingerprint (see below).
#
# Usage:
#   1. Start PolyFlare (in another shell):
#        polyflare serve                       # default 127.0.0.1:8080
#   2. Run codex through it:
#        codex-polyflare "summarize this repo"
#        codex-polyflare --model gpt-5.6-sol "..."   # pick a model your PolyFlare pool serves
#
# Capture the real codex-rs fingerprint golden (for the fingerprint-parity gate):
#   POLYFLARE_CAPTURE_FINGERPRINT=/tmp/codex_golden.jsonl polyflare serve
#   codex-polyflare "hi"                        # one request → /tmp/codex_golden.jsonl written
#
# Env overrides:
#   POLYFLARE_URL         PolyFlare base URL           (default http://127.0.0.1:8080)
#   POLYFLARE_CODEX_HOME  isolated CODEX_HOME to use   (default $HOME/.codex-polyflare)
#
set -euo pipefail

POLYFLARE_URL="${POLYFLARE_URL:-http://127.0.0.1:8080}"
CODEX_HOME_DIR="${POLYFLARE_CODEX_HOME:-$HOME/.codex-polyflare}"

command -v codex >/dev/null 2>&1 || {
  echo "codex-polyflare: the 'codex' CLI is not on PATH. Install the real Codex CLI first." >&2
  exit 127
}

mkdir -p "$CODEX_HOME_DIR"

# Regenerated every run (idempotent) so it always tracks POLYFLARE_URL. Codex forms the
# request URL as <base_url>/responses, and PolyFlare serves POST /responses at the root, so
# base_url is PolyFlare's address WITHOUT a /v1 suffix.
cat > "$CODEX_HOME_DIR/config.toml" <<EOF
# Auto-generated by scripts/codex-polyflare — points the Codex CLI at a local PolyFlare server.
# Do not edit; re-run codex-polyflare to regenerate. This is a SEPARATE CODEX_HOME from ~/.codex.
model_provider = "polyflare"

[model_providers.polyflare]
name = "PolyFlare (local dev)"
base_url = "${POLYFLARE_URL}"
wire_api = "responses"
# PolyFlare selects an account from its own pool and supplies the real upstream bearer, so the
# client-side token here is a placeholder PolyFlare ignores — no \`codex login\` is required.
experimental_bearer_token = "polyflare-local-dev"
EOF

exec env CODEX_HOME="$CODEX_HOME_DIR" codex "$@"
